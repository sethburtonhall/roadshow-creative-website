---
import '@/styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title = 'Full-Stack Development & Technical Leadership — Roadshow Creative',
  description = "Embedded technical lead & full-stack engineering for agencies & founders building SaaS and AI products. Oceanside-based, nationwide.",
  ogImage = '/og-image.jpg',
  canonicalUrl = Astro.url.href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://roadshowcreative.dev')} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Roadshow Creative" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? 'https://roadshowcreative.dev')} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Roadshow Creative",
      "url": "https://roadshowcreative.dev",
      "logo": "https://roadshowcreative.dev/favicon.svg",
      "image": "https://roadshowcreative.dev/og-image.jpg",
      "description": "Full-stack development studio specializing in embedded technical leadership, agentic engineering, and SaaS development for agencies and founders.",
      "founder": {
        "@type": "Person",
        "name": "Seth Hall",
        "jobTitle": "Founder & Full-Stack Developer",
        "description": "15+ years of experience building ambitious web products",
        "url": "https://roadshowcreative.dev",
        "sameAs": [
          "https://github.com/sethburtonhall",
          "https://www.linkedin.com/in/sethburtonhall/"
        ]
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Oceanside",
        "addressLocality": "Oceanside",
        "addressRegion": "CA",
        "postalCode": "92054",
        "addressCountry": "US"
      },
      "areaServed": ["US", "Worldwide"],
      "serviceType": ["Full-Stack Web Development", "SaaS Development", "Technical Leadership", "Agentic Engineering", "Frontend Engineering"],
      "knowsAbout": ["Full-Stack Development", "Next.js", "TypeScript", "React", "PostgreSQL", "Vercel", "AI Agents", "SaaS Architecture", "Technical Leadership"]
    })} />

    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Roadshow Creative",
      "image": "https://roadshowcreative.dev/og-image.jpg",
      "description": "Full-stack development studio in San Diego area specializing in technical leadership and SaaS development.",
      "url": "https://roadshowcreative.dev",
      "telephone": "",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Oceanside",
        "addressLocality": "Oceanside",
        "addressRegion": "CA",
        "postalCode": "92054",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoShape",
        "areaServed": ["San Diego County", "California", "United States"]
      },
      "priceRange": "$$$$"
    })} />


    <!-- Google Fonts: Plus Jakarta Sans + Bebas Neue + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Skip to content link for keyboard users -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only fixed top-2 left-2 z-50 bg-accent text-base px-4 py-2 rounded-card font-semibold focus:outline-none"
    >
      Skip to main content
    </a>

    <div id="main-content">
      <slot />
    </div>

    <Analytics />

    <!-- Scroll animation observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
