---
import ProjectCard from '@/components/ui/ProjectCard.astro';
import CaseStudyCard from '@/components/ui/CaseStudyCard.astro';
import { projects } from '@/data/projects';
import { caseStudies } from '@/data/caseStudies';

interface Props {
  id?: string;
}
const { id = 'work' } = Astro.props;
---

<section
  id={id}
  class="py-section-lg px-8 max-w-[1200px] mx-auto"
>
  <!-- Section header -->
  <div data-animate class="flex items-end justify-between mb-14 gap-8 flex-wrap">
    <div>
      <div class="section-label mb-4">Selected Work</div>
      <h2 class="text-headline text-text m-0">FEATURED WORK</h2>
    </div>
    <p class="text-[0.9375rem] text-text-muted max-w-[320px] m-0 leading-[1.65] text-right sm:text-right max-sm:text-left work-subtext">
      SaaS products and client projects — from concept through scale.
    </p>
  </div>

  <!-- Projects grid -->
  <div
    data-animate-stagger
    class="grid gap-6 grid-cols-[repeat(auto-fill,minmax(min(100%,520px),1fr))]"
  >
    {projects.map((project) => (
      <ProjectCard {...project} />
    ))}

    <!-- Placeholder cards container -->
    <div class="contents">
      <!-- Placeholder card: coming soon -->
      <article class="bg-surface border border-dashed border-border rounded-card p-8 flex flex-col items-start justify-center gap-3 min-h-[220px]">
        <span class="font-mono text-[0.625rem] tracking-[0.18em] uppercase text-text-dim">Next project</span>
        <p class="font-display text-[clamp(1.5rem,3vw,2rem)] text-in-progress m-0 tracking-[0.03em]">IN PROGRESS</p>
        <p class="text-sm text-text-dim m-0 leading-[1.6]">Something new is being built. Check back soon.</p>
      </article>

      <!-- NDA note card -->
      <article class="bg-surface border border-dashed border-border rounded-card p-8 flex flex-col items-start justify-center gap-3 min-h-[220px]">
        <span class="font-mono text-[0.625rem] tracking-[0.18em] uppercase text-text-dim">Client work</span>
        <p class="font-display text-[clamp(1.5rem,3vw,2rem)] text-text m-0 tracking-[0.03em]">UNDER NDA</p>
        <p class="text-sm text-text-dim m-0 leading-[1.6]">Most client work is confidential. <a href="#contact" class="text-text-muted underline underline-offset-2 hover:text-text transition-colors duration-200">Happy to discuss on a call.</a></p>
      </article>
    </div>
  </div>

  <!-- Case Studies Section -->
  <div class="mt-section-lg pt-section-lg border-t border-border" id="casestudies">
    <div data-animate class="flex items-end justify-between mb-14 gap-8 flex-wrap">
      <div>
        <div class="section-label mb-4">Recent Engagements</div>
        <h3 class="text-headline text-text m-0">CASE STUDIES</h3>
      </div>
      <p class="text-[0.9375rem] text-text-muted max-w-[320px] m-0 leading-[1.65] text-right sm:text-right max-sm:text-left">
        Modernization and architectural leadership across industries.
      </p>
    </div>

    <!-- Case studies grid -->
    <div
      data-animate-stagger
      class="grid gap-6 grid-cols-[repeat(auto-fill,minmax(min(100%,520px),1fr))]"
    >
      {caseStudies.map((caseStudy) => (
        <CaseStudyCard {...caseStudy} />
      ))}
    </div>
  </div>
</section>
