---
import { ArrowRight } from "@lucide/astro";
---

<section
  id="hero"
  class="relative min-h-svh flex flex-col justify-center pt-32 pb-20 px-8 overflow-hidden"
>
  <!-- Ambient spotlight glow -->
  <div
    class="spotlight absolute w-[min(80vw,800px)] h-[min(80vw,800px)] -top-[20%] -left-[15%]"
    aria-hidden="true"
  ></div>

  <!-- Background grid lines -->
  <div
    class="grid-lines absolute inset-0 opacity-40 pointer-events-none"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-2 max-w-[1200px] mx-auto w-full">

    <!-- Label -->
    <div class="section-label mb-8" data-animate>
      Freelance Dev Studio
    </div>

    <!-- Main headline -->
    <h1 data-animate class="text-hero text-text leading-[0.9] tracking-[0.01em] mb-[0.2em]">
      ROADSHOW<br />
      <span style="-webkit-text-stroke: 1px rgba(242, 240, 235, 0.25);" class="text-transparent">CREATIVE</span>
    </h1>

    <!-- Subtext row -->
    <div data-animate class="flex items-start gap-12 mt-10 flex-wrap">
      <p class="text-lead text-text-muted max-w-[440px] m-0 leading-[1.6]">
        Full-stack engineering and technical leadership for ambitious founders and teams. From concept to production.
      </p>

      <!-- Vertical divider + availability badge -->
      <div class="hidden sm:flex sm:flex-col gap-3 pl-12 border-l border-accent-2">
        <div class="flex items-center gap-2">
          <span
            class="w-[6px] h-[6px] rounded-full bg-live shrink-0 shadow-[0_0_6px_var(--color-live)]"
          ></span>
          <span class="font-mono text-label tracking-[0.12em] text-text-muted uppercase">Available for work</span>
        </div>
        <span class="font-mono text-label tracking-widest text-text-dim uppercase">Oceanside, CA</span>
      </div>
    </div>

    <!-- CTA row -->
    <div data-animate class="flex gap-4 mt-12 flex-wrap">
      <a href="#work" class="btn-primary">
        See the Work
        <ArrowRight size={16} />
      </a>
      <a href="#contact" class="btn-ghost">Let's Talk</a>
    </div>

    <!-- Scroll indicator -->
    <div data-animate class="absolute -bottom-14 left-0 flex items-center gap-3">
      <div
        class="w-px h-12 bg-[linear-gradient(to_bottom,var(--color-accent-2),transparent)]"
      ></div>
      <span class="font-mono text-label tracking-[0.15em] text-text-dim uppercase [writing-mode:vertical-rl]">Scroll</span>
    </div>

    <!-- Large background numeral -->
    <div aria-hidden="true" class="absolute -right-8 -top-12 font-display text-[clamp(12rem,28vw,22rem)] leading-none text-transparent pointer-events-none select-none tracking-[-0.02em] z-1" style="-webkit-text-stroke: 1px var(--color-border);">01</div>

  </div>
</section>
