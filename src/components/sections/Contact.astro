---
import ContactForm from "@/components/ContactForm.astro";

interface Props {
  id?: string;
}
const { id = 'contact' } = Astro.props;
---

<section
  id={id}
  class="py-section-lg px-8 bg-surface border-t border-border relative overflow-hidden"
>
  <!-- Ambient glow -->
  <div
    aria-hidden="true"
    class="absolute bottom-[-40%] left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-[radial-gradient(ellipse_at_center,rgba(249,115,22,0.1)_0%,transparent_65%)] pointer-events-none rounded-full"
  ></div>

  <div class="max-w-[900px] mx-auto text-center relative z-1">
    <!-- Label -->
    <div data-animate class="flex justify-center mb-6">
      <div class="section-label">Get in Touch</div>
    </div>

    <!-- Headline -->
    <h2 data-animate class="text-headline text-text mb-6">
      LET'S BUILD<br />
      <span style="-webkit-text-stroke: 1px rgba(242, 240, 235, 0.3);" class="text-transparent">SOMETHING</span>
    </h2>

    <!-- Sub text -->
    <p data-animate class="text-lead text-text-muted max-w-[500px] mx-auto mb-12 leading-[1.65]">
      Open to new engagements. Whether you're an agency that needs an embedded technical lead, or a founder ready to ship — reach out.
    </p>

    <!-- Contact Form -->
    <div data-animate class="mb-8">
      <ContactForm />
    </div>

    <!-- Response note -->
    <p data-animate class="font-mono text-label tracking-[0.12em] uppercase text-text-dim">
      Typically respond within 24 hours
    </p>
  </div>
</section>
