---
// Nav — fixed, transparent → frosted glass on scroll
---

<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-100 px-8 h-16 flex items-center justify-between bg-transparent border-b border-transparent transition-[background,border-color,backdrop-filter] duration-320 ease-[cubic-bezier(0.4,0,0.2,1)]"
>
  <!-- Logo -->
  <a
    href="/"
    class="flex items-center gap-2 no-underline text-text"
  >
    <!-- Compass mark -->
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect width="28" height="28" rx="3" fill="var(--color-accent)"/>
      <g transform="translate(4, 4) scale(0.8333)" stroke="#0C0C0E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <path d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z" />
      </g>
    </svg>
    <span class="font-display text-xl tracking-[0.06em] text-text">Roadshow Creative</span>
  </a>

  <!-- Desktop links -->
  <div class="nav-links hidden sm:flex items-center gap-10">
    <a href="#work" class="nav-link font-body text-sm font-medium text-text-muted no-underline tracking-[0.01em] transition-colors duration-320 ease-[cubic-bezier(0.4,0,0.2,1)] hover:text-text">Work</a>
    <a href="#about" class="nav-link font-body text-sm font-medium text-text-muted no-underline tracking-[0.01em] transition-colors duration-320 ease-[cubic-bezier(0.4,0,0.2,1)] hover:text-text">About</a>
    <a href="#services" class="nav-link font-body text-sm font-medium text-text-muted no-underline tracking-[0.01em] transition-colors duration-320 ease-[cubic-bezier(0.4,0,0.2,1)] hover:text-text">Services</a>
  </div>

  <!-- CTA -->
  <a href="#contact" class="btn-primary py-2 px-5 text-[0.8125rem]">
    Let's Talk
  </a>
</nav>

<script>
  const nav = document.getElementById('nav');
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 60) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
