---
interface Service {
  number: string;
  title: string;
  description: string;
  tags?: string[];
  link: string;
}

interface Props {
  services: Service[];
  numeral: string;
  title?: string;
  label?: string;
  sectionId?: string;
}

const { services, numeral, title = "WHAT WE OFFER", label = "Services", sectionId = "services" } = Astro.props;

import { ArrowRight } from '@lucide/astro';
---

<section id={sectionId} class="py-section-lg px-8 bg-surface border-t border-b border-border relative overflow-hidden">
  <!-- Background numeral -->
  <div
    aria-hidden="true"
    class="absolute -right-8 top-8 font-display text-[clamp(10rem,24vw,20rem)] leading-none text-transparent pointer-events-none select-none z-0"
    style="-webkit-text-stroke: 1px var(--color-border-subtle);"
  >
    {numeral}
  </div>

  <div class="max-w-[1200px] mx-auto relative z-1">
    <div data-animate class="mb-16">
      <div class="section-label mb-4">{label}</div>
      <h2 class="text-headline text-text m-0">{title}</h2>
    </div>

    <!-- Services list -->
    <div class="relative z-1">
      {services.map((service) => (
        <div class="service-item grid max-sm:grid-cols-[3.5rem_1fr] grid-cols-[5rem_1fr_auto] gap-8 items-start py-10 border-t border-border hover:bg-surface/50 transition-colors px-0 group" data-animate>
          <div class="service-number font-display text-[3.5rem] leading-none text-border group-hover:text-accent tracking-[0.02em] transition-colors duration-320 shrink-0">{service.number}</div>
          <div>
            <h3 class="font-display text-[clamp(1.75rem,3.5vw,2.75rem)] leading-none tracking-[0.02em] text-text mb-3.5">{service.title}</h3>
            <p class="text-[0.9375rem] leading-[1.7] text-text-muted mb-5 max-w-[540px]">{service.description}</p>
            {service.tags && service.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {service.tags.map((tag) => (
                  <span class="font-mono text-[0.6rem] tracking-[0.12em] uppercase text-text-dim border border-border rounded-sm px-2 py-[0.2rem] bg-surface">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <div class="service-arrow max-sm:hidden mt-2 text-border group-hover:text-accent group-hover:translate-x-1 transition-all duration-320 shrink-0 flex items-center justify-center">
            <ArrowRight size={20} />
          </div>
        </div>
      ))}
      {services.length > 0 && <div class="border-b border-border"></div>}
    </div>
  </div>

  <style>
    .service-item:hover .service-number {
      color: var(--color-accent);
    }

    .service-item:hover .service-arrow {
      color: var(--color-accent);
      transform: translate(2px, -2px);
    }
  </style>
</section>
