---
import { Compass, Menu, X } from "@lucide/astro";

interface Props {
  locationName: string;
}

const { locationName } = Astro.props;

// Location-specific sections based on the page structure
const locationSections = [
  { id: 'clients', label: 'Clients' },
  { id: 'services', label: 'Services' },
  { id: 'advantages', label: 'Why Local' },
  { id: 'recent-work', label: 'Recent Work' },
  { id: 'our-story', label: 'Our Story' },
];
---
<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-100 px-8 h-16 flex items-center justify-between bg-transparent border-b border-transparent transition-[background,border-color,backdrop-filter] duration-320 ease-[cubic-bezier(0.4,0,0.2,1)]"
>
<div class="flex items-center gap-4">
  <!-- Logo -->
  <a
    href="/"
    class="flex items-center gap-1 no-underline text-text"
  >
    <!-- Compass mark -->
    <div class="w-7 h-7 text-accent flex items-center justify-center">
      <Compass size={20} />
    </div>
    <span class="font-display text-xl tracking-[0.06em] text-text">Roadshow Creative</span>
  </a>
  <!-- Location indicator -->
    <div class="hidden xl:flex items-center gap-2 px-3 py-1 bg-surface-2 border border-border rounded-sm">
      <span class="font-mono text-label tracking-[0.08em] uppercase text-text-muted">{locationName}</span>
    </div>
  </div>


  <!-- Desktop links -->
  <div class="nav-links hidden lg:flex items-center gap-10">
    {locationSections.map((section) => (
      <a
        href={`#${section.id}`}
        data-nav-link={section.id}
        class="nav-link font-body text-sm font-medium text-text-muted no-underline tracking-[0.01em] transition-colors duration-320 ease-[cubic-bezier(0.4,0,0.2,1)] hover:text-text relative"
      >
        {section.label}
        <span class="nav-indicator absolute -left-3 top-1/2 -translate-y-1/2 w-1 h-1 rounded-full bg-accent opacity-0 transition-opacity duration-320"></span>
      </a>
    ))}
    <a
      href="/faq"
      data-nav-link="faq"
      class="nav-link font-body text-sm font-medium text-text-muted no-underline tracking-[0.01em] transition-colors duration-320 ease-[cubic-bezier(0.4,0,0.2,1)] hover:text-text relative"
    >
      FAQ
      <span class="nav-indicator absolute -left-3 top-1/2 -translate-y-1/2 w-1 h-1 rounded-full bg-accent opacity-0 transition-opacity duration-320"></span>
    </a>
  </div>

  <!-- Mobile menu button (replaces CTA on mobile) -->
  <button
    id="mobile-menu-btn"
    class="lg:hidden p-2 text-text-muted hover:text-text transition-colors duration-200 cursor-pointer"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
  >
    <Menu size={20} class="block mobile-menu-icon-open" />
    <X size={20} class="hidden mobile-menu-icon-close" />
  </button>

  <!-- CTA (desktop only) -->
  <a href="/#contact" class="btn-primary py-2 px-5 text-[0.8125rem] !hidden lg:!inline-flex" aria-label="Contact CTA">
    Let's Talk
  </a>
</nav>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu"
  class="fixed top-16 left-0 right-0 bottom-0 bg-base hidden flex flex-col gap-6 px-8 py-8 overflow-y-auto z-99"
>
  {locationSections.map((section) => (
    <a href={`#${section.id}`} class="w-full font-body text-base font-medium text-text no-underline hover:text-accent transition-colors duration-200">{section.label}</a>
  ))}
  <a href="/faq" class="w-full font-body text-base font-medium text-text no-underline hover:text-accent transition-colors duration-200">FAQ</a>
  <a href="/#contact" class="btn-primary py-3 px-6 text-center w-full">Let's Talk</a>
</div>

<script>
  const nav = document.getElementById('nav');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuOpen = mobileMenuBtn?.querySelector('.mobile-menu-icon-open');
  const mobileMenuClose = mobileMenuBtn?.querySelector('.mobile-menu-icon-close');

  // Toggle mobile menu
  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden') === false;
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
      mobileMenuOpen?.classList.remove('hidden');
      mobileMenuClose?.classList.add('hidden');
    } else {
      mobileMenu?.classList.remove('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'true');
      mobileMenuOpen?.classList.add('hidden');
      mobileMenuClose?.classList.remove('hidden');
    }
  });

  // Close menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenuBtn.setAttribute('aria-expanded', 'false');
      mobileMenuOpen?.classList.remove('hidden');
      mobileMenuClose?.classList.add('hidden');
    });
  });

  // Scroll effects and active section indicator
  const onScroll = () => {
    if (!nav) return;

    // Add scroll effect
    if (window.scrollY > 60) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }

    // Update active section indicator
    const navLinks = document.querySelectorAll('[data-nav-link]');

    // Clear all indicators first
    navLinks.forEach(link => {
      const indicator = link?.querySelector('.nav-indicator');
      indicator?.classList.remove('opacity-100');
      indicator?.classList.add('opacity-0');
    });

    // Check if we're on the FAQ page (ignore hash fragments)
    const currentPath = window.location.pathname;
    if (currentPath === '/faq') {
      const faqLink = document.querySelector('[data-nav-link="faq"]');
      const faqIndicator = faqLink?.querySelector('.nav-indicator');
      faqIndicator?.classList.add('opacity-100');
      faqIndicator?.classList.remove('opacity-0');
      return;
    }

    // Location-specific sections
    const sections = ['clients', 'services', 'advantages', 'recent-work', 'our-story'];
    
    // Find the section that's most in view
    let bestSection = null;
    let bestScore = Infinity;

    sections.forEach(section => {
      const element = document.getElementById(section);
      if (!element) return;

      const rect = element.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      const navHeight = 64; // Approximate nav height
      
      // Calculate how far the section top is from the ideal position (just below nav)
      const distanceFromIdeal = Math.abs(rect.top - navHeight);
      
      // Only consider sections that are at least partially visible
      const isVisible = rect.bottom > navHeight && rect.top < viewportHeight;
      
      if (isVisible && distanceFromIdeal < bestScore) {
        bestScore = distanceFromIdeal;
        bestSection = section;
      }
    });

    // Highlight the best section
    if (bestSection) {
      const link = document.querySelector(`[data-nav-link="${bestSection}"]`);
      const indicator = link?.querySelector('.nav-indicator');
      indicator?.classList.add('opacity-100');
      indicator?.classList.remove('opacity-0');
    }
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // Call on load
</script>
