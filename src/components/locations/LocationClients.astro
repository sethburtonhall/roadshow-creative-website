---
interface Client {
  number: string;
  title: string;
  description: string;
}

interface Props {
  numeral: string;
  clients: Client[];
  sectionId?: string;
}

const { numeral, clients, sectionId } = Astro.props;

import { ArrowRight } from '@lucide/astro';
---

<section id={sectionId} class="py-section-lg px-8 relative overflow-hidden">
  <!-- Background numeral -->
  <div
    aria-hidden="true"
    class="absolute -right-8 top-8 font-display text-[clamp(10rem,24vw,20rem)] leading-none text-transparent pointer-events-none select-none z-0"
    style="-webkit-text-stroke: 1px var(--color-border-subtle);"
  >
    {numeral}
  </div>

  <div class="max-w-[1200px] mx-auto relative z-1">
    <div data-animate class="mb-16">
      <div class="section-label mb-4">Who We Work With</div>
      <h2 class="text-headline text-text m-0">OUR CLIENTS</h2>
    </div>

    <div class="space-y-0">
      {clients.map((client, index) => (
        <div data-animate class="grid max-sm:grid-cols-[3.5rem_1fr] grid-cols-[5rem_1fr_auto] gap-8 items-start py-10 border-t border-border hover:bg-surface/50 transition-colors px-0 group">
          <div class="font-display text-[3.5rem] leading-none text-border group-hover:text-accent transition-colors duration-320 tracking-[0.02em] shrink-0">{client.number}</div>
          <div>
            <h3 class="font-display text-[clamp(1.75rem,3.5vw,2.75rem)] leading-none tracking-[0.02em] text-text mb-3.5">{client.title}</h3>
            <p class="text-[0.9375rem] leading-[1.7] text-text-muted mb-5 max-w-[540px]">{client.description}</p>
          </div>
          <div class="max-sm:hidden mt-2 text-border group-hover:text-accent group-hover:translate-x-1 transition-all duration-320 shrink-0 flex items-center justify-center">
            <ArrowRight size={20} />
          </div>
        </div>
      ))}
      {clients.length > 0 && <div class="border-b border-border"></div>}
    </div>
  </div>
</section>
