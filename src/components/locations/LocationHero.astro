---
import { ArrowRight } from '@lucide/astro';

interface Props {
  title: string;
  titleAlt?: string;
  subtitle: string;
  numeral: string;
  label?: string;
  statusBadge?: string;
  statusLabel?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const {
  title,
  titleAlt,
  subtitle,
  numeral,
  label = "Local Focus",
  statusBadge = "Available Now",
  statusLabel = "Oceanside, CA",
  ctaText = "Let's Talk",
  ctaHref = "/#contact",
  secondaryCtaText = "Explore Services",
  secondaryCtaHref = "/#services"
} = Astro.props;
---

<section class="relative min-h-svh flex flex-col justify-center pt-32 pb-20 px-8 overflow-hidden">
  <!-- Spotlight glow -->
  <div
    class="spotlight absolute w-[min(80vw,800px)] h-[min(80vw,800px)] -top-[20%] -left-[15%]"
    aria-hidden="true"
  ></div>

  <!-- Grid lines -->
  <div
    class="grid-lines absolute inset-0 opacity-40 pointer-events-none"
    aria-hidden="true"
  ></div>

  <!-- Background numeral -->
  <div
    aria-hidden="true"
    class="absolute -right-8 -top-12 font-display text-[clamp(12rem,28vw,22rem)] leading-none text-transparent pointer-events-none select-none tracking-[-0.02em] z-1"
    style="-webkit-text-stroke: 1px var(--color-border);"
  >
    {numeral}
  </div>

  <!-- Content -->
  <div class="relative z-2 max-w-[1200px] mx-auto w-full">
    <div class="section-label mb-8" data-animate>{label}</div>
    <h1 data-animate class="text-hero text-text leading-[0.9] tracking-[0.01em] mb-[0.2em]">
      {title}<br />
      <span style="-webkit-text-stroke: 1px rgba(242, 240, 235, 0.25);" class="text-transparent">{titleAlt}</span>
    </h1>

    <!-- Subtext row -->
    <div data-animate class="flex items-start gap-12 mt-10 flex-wrap">
      <p class="text-lead text-text-muted max-w-[440px] m-0 leading-[1.6]">
        {subtitle}
      </p>

      <!-- Vertical divider + location badge -->
      <div class="hidden sm:flex sm:flex-col gap-3 pl-12 border-l border-accent-2">
        <div class="flex items-center gap-2">
          <span
            class="w-[6px] h-[6px] rounded-full bg-live shrink-0 shadow-[0_0_6px_var(--color-live)]"
          ></span>
          <span class="font-mono text-label tracking-[0.12em] text-text-muted uppercase">{statusBadge}</span>
        </div>
        <span class="font-mono text-label tracking-widest text-text-dim uppercase">{statusLabel}</span>
      </div>
    </div>

    <!-- CTA row -->
    <div data-animate class="flex gap-4 mt-12 flex-wrap">
      <a href={ctaHref} class="btn-primary">
        {ctaText}
        <ArrowRight size={16} />
      </a>
      <a href={secondaryCtaHref} class="btn-ghost">{secondaryCtaText}</a>
    </div>

    <!-- Scroll indicator -->
    <div data-animate class="absolute -bottom-14 left-0 flex items-center gap-3">
      <div
        class="w-px h-12 bg-[linear-gradient(to_bottom,var(--color-accent-2),transparent)]"
      ></div>
      <span class="font-mono text-label tracking-[0.15em] text-text-dim uppercase [writing-mode:vertical-rl]">Scroll</span>
    </div>
  </div>

  <style>
    .spotlight {
      background: radial-gradient(
        circle,
        rgba(245, 165, 36, 0.15) 0%,
        rgba(245, 165, 36, 0.08) 30%,
        transparent 70%
      );
      filter: blur(60px);
    }

    .grid-lines {
      background-image:
        linear-gradient(90deg, var(--color-border) 1px, transparent 1px),
        linear-gradient(0deg, var(--color-border) 1px, transparent 1px);
      background-size: 50px 50px;
    }
  </style>

