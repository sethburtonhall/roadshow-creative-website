---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LocationNav from '@/components/locations/LocationNav.astro';
import FooterBar from '@/components/ui/FooterBar.astro';
import { ArrowRight } from '@lucide/astro';
import LocationHero from '@/components/locations/LocationHero.astro';
import LocationMarket from '@/components/locations/LocationMarket.astro';
import LocationClients from '@/components/locations/LocationClients.astro';
import LocationServices from '@/components/locations/LocationServices.astro';
import LocationAdvantages from '@/components/locations/LocationAdvantages.astro';
import LocationRecentWork from '@/components/locations/LocationRecentWork.astro';
import LocationCTA from '@/components/locations/LocationCTA.astro';
import About from '@/components/sections/About.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Roadshow Creative — San Diego",
  "description": "Full-stack development studio serving San Diego area. Technical leadership, SaaS development, agentic engineering.",
  "url": "https://roadshowcreative.dev/locations/san-diego",
  "areaServed": {
    "@type": "City",
    "name": "San Diego"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Oceanside",
    "addressRegion": "CA",
    "postalCode": "92054",
    "addressCountry": "US"
  },
  "serviceType": ["Full-Stack Development", "Technical Leadership", "SaaS Development", "Agentic Engineering"]
};

const services = [
  {
    number: "01",
    title: "TECHNICAL LEADERSHIP",
    description: "CTO-level guidance, architecture, mentorship. Month-to-month or project-based engagement.",
    tags: ["Architecture", "Mentorship", "Scaling"],
    link: "/services/technical-leadership"
  },
  {
    number: "02",
    title: "SAAS DEVELOPMENT",
    description: "Full-stack product builds from MVP to scale. Founded companies love us.",
    tags: ["MVP", "Full-Stack", "Scaling"],
    link: "/services/saas-development"
  },
  {
    number: "03",
    title: "AGENTIC ENGINEERING",
    description: "AI agents that think and execute. Autonomous workflows for your business.",
    tags: ["LLMs", "Agents", "Automation"],
    link: "/services/agentic-engineering"
  },
  {
    number: "04",
    title: "FRONTEND ENGINEERING",
    description: "Pixel-perfect UI. Design systems. Partner with your design team.",
    tags: ["React", "Tailwind", "Design System"],
    link: "/services/frontend-engineering"
  }
];

const advantages = [
  {
    number: "01",
    label: "PRESENT",
    description: "In-person meetings, coffee chats, understanding local context and relationships"
  },
  {
    number: "02",
    label: "CONNECTED",
    description: "Deep relationships with local design, product, and startup communities"
  },
  {
    number: "03",
    label: "TIMEZONE",
    description: "Same timezone. Real-time collaboration. Standups without scheduling gymnastics."
  },
  {
    number: "04",
    label: "INVESTED",
    description: "We care about San Diego's tech ecosystem. We're long-term players here."
  },
  {
    number: "05",
    label: "EXPERIENCED",
    description: "15+ years building in this market. We've seen trends, understand what works.",
    fullWidth: true
  }
];

const recentWork = [
  {
    title: "Village",
    description: "Event discovery platform with live events, venues, and live streaming. Live product generating revenue.",
    link: "https://usevillage.app",
    external: true,
    tags: ["React", "Full-Stack", "Live"]
  },
  {
    title: "Client Projects",
    description: "20+ projects shipped. MVP development, platform scaling, team augmentation for startups and agencies across San Diego.",
    link: "/#casestudies",
    tags: ["SaaS", "Product", "Scale"]
  }
];

const clients = [
  {
    number: "01",
    title: "DESIGN & PRODUCT AGENCIES",
    description: "Building AI-powered products for clients? We're your technical partners. Frontend to backend, we handle the engineering so you focus on design and strategy."
  },
  {
    number: "02",
    title: "NORTH COUNTY STARTUPS",
    description: "Early-stage founders in Oceanside, Carlsbad, Vista? Embedded CTO/technical lead. Help navigate tech decisions, hire engineers, scale your platform."
  },
  {
    number: "03",
    title: "ESTABLISHED INDUSTRIES",
    description: "Complex domain + technical challenge? We build robust systems for any industry with sophisticated requirements."
  },
  {
    number: "04",
    title: "SCALING TEAMS",
    description: "Scaling from 3 to 5 engineers? We mentor, set standards, help hire the right people. Technical leadership to grow your team capability."
  }
];
---

<BaseLayout title="Full-Stack Development in San Diego — Roadshow Creative" description="Technical leadership and full-stack development services in San Diego, Oceanside, and surrounding areas. Local expertise, nationwide availability.">
  <LocationNav locationName="San Diego" />

  <main class="min-h-screen">
    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Hero Section -->
    <LocationHero
      title="TECHNICAL"
      titleAlt="LEADERSHIP"
      subtitle="Embedded technical lead for San Diego agencies and founders. Full-stack engineering, architecture, team scaling. Based in Oceanside."
      numeral="01"
      label="San Diego Market"
      statusBadge="Serving San Diego"
      statusLabel="Oceanside, CA"
    />

    <!-- Market Context -->
    <LocationMarket
      numeral="02"
      marketName="SAN DIEGO"
      landscapeTitle="LANDSCAPE"
      description="San Diego has a vibrant startup and design scene. Biotech, fintech, digital product agencies-all building ambitious products."
      localContext="Roadshow Creative is embedded right here in Oceanside. We understand the local market, work with agencies and founders, and are developing deep relationships in the community."
      callToAction="Need a technical co-founder? Designer agency building AI? Startup with 3 engineers struggling to scale? We're a quick message away."
    />

    <!-- Who We Work With -->
    <LocationClients
      numeral="03"
      clients={clients}
      sectionId="clients"
    />

    <!-- Services -->
    <LocationServices
      services={services}
      numeral="04"
      sectionId="services"
    />

    <!-- Advantages -->
    <LocationAdvantages
      title="WHY LOCAL MATTERS"
      advantages={advantages}
      numeral="05"
      sectionId="advantages"
    />

    <!-- Recent Work -->
    <LocationRecentWork
      recentWork={recentWork}
      numeral="06"
      sectionId="recent-work"
    />

    <!-- Our Story -->
    <About numeral="07" variant="story" id="our-story" />

    <!-- CTA -->
    <LocationCTA
      title="Ready to build?"
      subtitle="Oceanside-based technical leadership and full-stack development for San Diego founders and agencies."
    />
  </main>

  <FooterBar />
</BaseLayout>
