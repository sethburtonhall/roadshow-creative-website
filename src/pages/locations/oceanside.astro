---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LocationNav from '@/components/locations/LocationNav.astro';
import FooterBar from '@/components/ui/FooterBar.astro';
import { ArrowRight } from '@lucide/astro';
import LocationHero from '@/components/locations/LocationHero.astro';
import LocationMarket from '@/components/locations/LocationMarket.astro';
import LocationClients from '@/components/locations/LocationClients.astro';
import LocationServices from '@/components/locations/LocationServices.astro';
import LocationAdvantages from '@/components/locations/LocationAdvantages.astro';
import LocationRecentWork from '@/components/locations/LocationRecentWork.astro';
import LocationCTA from '@/components/locations/LocationCTA.astro';
import About from '@/components/sections/About.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Roadshow Creative — Oceanside",
  "description": "Full-stack development studio based in Oceanside, CA. Technical leadership, SaaS development, agentic engineering.",
  "url": "https://roadshowcreative.dev/locations/oceanside",
  "areaServed": {
    "@type": "City",
    "name": "Oceanside"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Oceanside",
    "addressRegion": "CA",
    "postalCode": "92054",
    "addressCountry": "US"
  },
  "serviceType": ["Full-Stack Development", "Technical Leadership", "SaaS Development", "Agentic Engineering"]
};

const services = [
  {
    number: "01",
    title: "TECHNICAL LEADERSHIP",
    description: "CTO-level guidance, architecture, mentorship. Month-to-month or project-based engagement.",
    tags: ["Architecture", "Mentorship", "Scaling"],
    link: "/services/technical-leadership"
  },
  {
    number: "03",
    title: "AGENTIC ENGINEERING",
    description: "AI agents that think and execute. Autonomous workflows for your business.",
    tags: ["LLMs", "Agents", "Automation"],
    link: "/services/agentic-engineering"
  },
  {
    number: "02",
    title: "SAAS DEVELOPMENT",
    description: "Full-stack product builds from MVP to scale. Seamless integration with your existing systems.",
    tags: ["MVP", "Full-Stack", "Scaling"],
    link: "/services/saas-development"
  },
  {
    number: "04",
    title: "FRONTEND ENGINEERING",
    description: "Pixel-perfect UI. Design systems. Partner with your design team.",
    tags: ["React", "Tailwind", "Design System"],
    link: "/services/frontend-engineering"
  }
];

const advantages = [
  {
    number: "01",
    label: "LOCAL",
    description: "In-person collaboration, coffee chats, understanding your market intimately."
  },
  {
    number: "02",
    label: "ACCESSIBLE",
    description: "Easy to reach. Responsive. Part of the Oceanside startup ecosystem."
  },
  {
    number: "03",
    label: "RELIABLE",
    description: "15+ years shipping products. Experienced with client engagement and startup growth."
  },
  {
    number: "04",
    label: "INVESTED",
    description: "We care about Oceanside and San Diego's success."
  },
  {
    number: "05",
    label: "CONNECTED",
    description: "Network across Oceanside, San Diego, and beyond. Help with introductions, advice, partnerships.",
    fullWidth: true
  }
];

const recentWork = [
  {
    title: "Village",
    description: "Event discovery platform. Live events, venues, live streaming. Production deployed and scaling.",
    link: "https://usevillage.app",
    external: true,
    tags: ["React", "Full-Stack", "Live"]
  },
  {
    title: "Client Projects",
    description: "MVP development, platform scaling, team augmentation. North County and beyond.",
    link: "/#casestudies",
    tags: ["SaaS", "Product", "Scale"]
  }
];

const clients = [
  {
    number: "01",
    title: "DESIGN & PRODUCT AGENCIES",
    description: "Building AI-powered products for clients? We're your technical partners. Frontend to backend, we handle the engineering so you focus on design and strategy."
  },
  {
    number: "02",
    title: "NORTH COUNTY STARTUPS",
    description: "Early-stage founders in Oceanside, Carlsbad, Vista? Embedded CTO/technical lead. Help navigate tech decisions, hire engineers, scale your platform."
  },
  {
    number: "03",
    title: "ESTABLISHED INDUSTRIES",
    description: "Complex domain + technical challenge? We build robust systems for any industry with sophisticated requirements."
  },
  {
    number: "04",
    title: "SCALING TEAMS",
    description: "Scaling from 3 to 5 engineers? We mentor, set standards, help hire the right people. Technical leadership to grow your team capability."
  }
];
---

<BaseLayout title="Full-Stack Development Services in Oceanside, CA — Roadshow Creative" description="Oceanside-based full-stack development studio. Technical leadership, SaaS MVP development, agentic engineering. 15+ years experience.">
  <LocationNav locationName="Oceanside" />

  <main class="min-h-screen">
    <!-- LocalBusiness Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Hero Section -->
    <LocationHero
      title="SHIP FROM"
      titleAlt="OCEANSIDE"
      subtitle="Embedded technical lead for founders and agencies. Full-stack engineering, architecture, product strategy. Based right here, serving globally."
      numeral="01"
      label="Oceanside First"
      statusBadge="Available Now"
      statusLabel="Oceanside, CA"
    />

    <!-- Oceanside Culture -->
    <LocationMarket
      numeral="02"
      marketName="OCEANSIDE"
      landscapeTitle="FIRST"
      description="Oceanside is a tech haven. Laid-back vibe, zero ego, serious builders. We're part of that community."
      localContext={`You can grab coffee with us. Collaborate in person. See the product come to life. No "outsourced development team" vibes-we're here, we're committed, we care about the outcome.`}
      callToAction={`Looking for a technical co-founder? Oceanside startup? Team needing technical leadership? We're neighbors.`}
    />

    <!-- Who We Work With -->
    <LocationClients
      numeral="03"
      clients={clients}
      sectionId="clients"
    />

    <!-- Services -->
    <LocationServices
      services={services}
      numeral="04"
      sectionId="services"
    />

    <!-- Advantages -->
    <LocationAdvantages
      title="WHY OCEANSIDE"
      advantages={advantages}
      numeral="05"
      sectionId="advantages"
    />

    <!-- Recent Work -->
    <LocationRecentWork
      recentWork={recentWork}
      numeral="06"
      sectionId="recent-work"
    />

    <!-- Our Story -->
    <About numeral="07" variant="story" id="our-story" />

    <!-- CTA -->
    <LocationCTA
      title="Ready to build?"
      subtitle="Let's grab coffee and talk about your project."
    />
  </main>

  <FooterBar />
</BaseLayout>
