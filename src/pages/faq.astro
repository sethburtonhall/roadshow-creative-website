---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import FooterBar from '@/components/ui/FooterBar.astro';

const faqs = [
  {
    question: "What is embedded technical leadership?",
    answer: "Embedded technical leadership means we work as an extension of your team—not as an outside vendor. We provide strategic technical guidance, architecture decisions, code standards, and hands-on development alongside your team. Ideal for agencies building AI products or founders moving fast without a full-time CTO."
  },
  {
    question: "How is Roadshow Creative different from hiring a full-time engineer?",
    answer: "We combine the strategic focus of a CTO with hands-on agentic engineering. Unlike a full-time hire, you get immediate expertise, flexibility in engagement, and no overhead costs. We're aligned with your timeline and can scale up or down as needed."
  },
  {
    question: "What's included in the technical leadership service?",
    answer: "Technical leadership includes architecture design, code review, mentoring your team, setting up development processes, technology stack recommendations, and hands-on development. We ensure your product is built to scale from day one."
  },
  {
    question: "How long does SaaS MVP development typically take?",
    answer: "In the past, developing MVPs could take 6–12 weeks, depending on complexity. Today, with agentic engineering, we can deliver them significantly faster—usually in half the time or less. Our focus is on swiftly shipping the core value proposition, validating with users, and iterating based on feedback. This speed is intentional: move fast, learn from users, and refine the product."
  },
  {
    question: "Do you work with non-technical founders?",
    answer: "Yes. We translate technical concepts into business outcomes. We'll explain architecture, costs, timelines, and trade-offs in terms that make sense for your business, not just technical jargon."
  },
  {
    question: "What tech stack do you recommend?",
    answer: "Our stack — Next.js, TypeScript, React, and PostgreSQL — has been refined over 15 years so your project starts on solid ground and scales effectively. We layer in Agentic Engineering from day one, using AI-driven automation to move faster and adapt as your needs evolve. Battle-tested tools, thriving communities behind them, and always scoped to what actually fits your project — no bloat, no dogma."
  },
  {
    question: "How do you handle AI agent integration?",
    answer: "Agentic engineering is our specialty. We design AI workflows that think, plan, and execute autonomously. From LLM integration to multi-step reasoning, we build systems that handle complex tasks reliably."
  },
  {
    question: "Can you scale with our team as we grow?",
    answer: "Absolutely. We start embedded with your core product decisions and scale to cover more surface area as you grow—frontend, backend, infrastructure, DevOps. We set up processes so your team can build independently."
  },
  {
    question: "What's your typical engagement model?",
    answer: "We work month-to-month or project-based. Most engagements start at 20-40 hours/week and adjust based on needs. We're flexible—whether you need full-time focus or strategic input a few hours a week."
  },
  {
    question: "How do you approach design and engineering collaboration?",
    answer: "Design and engineering aren't separate—they're one process. We work directly with your design team to understand the vision, then build interfaces that are both beautiful and performant. Pixel-precise, scalable, accessible."
  },
  {
    question: "Do you take equity or revenue share?",
    answer: "We work on time-based engagement. Some early-stage founders propose equity conversations separately—that's something we discuss individually. Primary model is straightforward hourly/project rates."
  },
  {
    question: "How do you stay current with AI and new technologies?",
    answer: "Continuous learning is built in. We experiment, ship side projects, and integrate what works into client projects. 15+ years means we've seen trends come and go—we focus on fundamentals + pragmatic innovation."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<BaseLayout title="FAQ — Roadshow Creative" description="Frequently asked questions about embedded technical leadership, full-stack development, and SaaS engineering at Roadshow Creative.">
  <Nav />

  <main class="min-h-screen flex flex-col" style="background-color: var(--color-base)">
    <!-- FAQ Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

    <!-- Header -->
    <section class="py-16 md:py-32 px-6 relative overflow-hidden" style="border-bottom: 1px solid var(--color-border-subtle)">
      <div class="absolute inset-0 -z-10 opacity-20">
        <div class="absolute top-0 right-0 w-96 h-96 rounded-full blur-3xl" style="background: radial-gradient(ellipse at center, rgba(245, 165, 36, 0.15) 0%, transparent 70%)"></div>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="text-sm uppercase tracking-wider font-mono mb-4" style="color: var(--color-accent)">Support</div>
        <h1 class="text-6xl md:text-7xl font-bold font-bebas mb-6 leading-none" style="color: var(--color-text)">FAQ</h1>
        <p class="text-lg max-w-2xl leading-relaxed" style="color: var(--color-text-muted)">Everything you need to know about working with Roadshow Creative. Can't find what you're looking for? <a href="/#contact" class="transition-colors font-semibold hover:opacity-80" style="color: var(--color-accent)">Let's talk.</a></p>
      </div>
    </section>

    <!-- FAQ List -->
    <section class="flex-1 py-16 md:py-32 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="space-y-1">
          {faqs.map((faq, index) => (
            <details class="faq-item group transition-all duration-300" key={index} style="border-top: 1px solid var(--color-border)">
              <summary class="flex items-center justify-between font-semibold cursor-pointer select-none py-6 px-0 transition-colors" style="color: var(--color-text)">
                <h2 class="text-base md:text-lg pr-4 group-open:opacity-80 transition-colors" style="color: inherit">{faq.question}</h2>
                <div class="flex-shrink-0 w-6 h-6 flex items-center justify-center transition-transform duration-300 group-open:rotate-180">
                  <svg class="w-5 h-5 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-accent)">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                  </svg>
                </div>
              </summary>
              <div class="faq-answer overflow-hidden transition-all duration-300 max-h-0 group-open:max-h-96">
                <div class="pb-6 pt-2 leading-relaxed text-sm md:text-base pr-8" style="color: var(--color-text-muted)">
                  {faq.answer}
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 md:py-32 px-6 relative overflow-hidden" style="border-top: 1px solid var(--color-border-subtle)">
      <div class="absolute inset-0 -z-10">
        <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full blur-3xl" style="background: radial-gradient(ellipse at center, rgba(245, 165, 36, 0.1) 0%, transparent 70%)"></div>
      </div>
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-5xl md:text-6xl font-bold font-bebas mb-6" style="color: var(--color-text)">Still have questions?</h2>
        <p class="text-lg mb-10 max-w-xl mx-auto" style="color: var(--color-text-muted)">We're here to discuss your project and explore how we can help bring your vision to life.</p>
        <a href="/#contact" class="inline-flex items-center gap-2 px-8 py-4 font-semibold transition-all duration-300 hover:gap-3 group" style="background-color: var(--color-accent); color: var(--color-base)">
          Start a Conversation
          <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <FooterBar />
</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] {
    background-color: rgba(20, 20, 18, 0.5);
    border-top-color: rgba(245, 165, 36, 0.4);
  }

  .faq-answer {
    animation: slideDown 300ms cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes slideDown {
    from {
      max-height: 0;
      opacity: 0;
    }
    to {
      max-height: 500px;
      opacity: 1;
    }
  }

  details[open] .faq-answer {
    animation: slideDown 300ms cubic-bezier(0.19, 1, 0.22, 1);
  }
</style>
